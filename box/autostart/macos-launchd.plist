<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.dilipod.cellar</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/dilipod</string>
        <string>run</string>
        <string>--daemon</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/tmp/dilipod-cellar.stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/dilipod-cellar.stderr.log</string>
    <key>WorkingDirectory</key>
    <string>/Users/Shared/.dilipod</string>
</dict>
</plist>
