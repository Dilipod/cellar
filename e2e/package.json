{
  "name": "@cellar/e2e",
  "version": "0.1.0",
  "private": true,
  "description": "End-to-end tests for the Cellar platform",
  "scripts": {
    "test": "playwright test --project=agent-engine --project=recorder --project=context-pipeline",
    "test:all": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report"
  },
  "devDependencies": {
    "@cellar/agent": "workspace:*",
    "@cellar/live-view": "workspace:*",
    "@cellar/recorder": "workspace:*",
    "@playwright/test": "^1.52.0",
    "ws": "^8.17.0",
    "@types/ws": "^8.5.0",
    "typescript": "^5.5.0"
  }
}
